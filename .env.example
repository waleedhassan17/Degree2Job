# ─────────────────────────────────────────────
# JobPulse PK — Environment Variables
# Copy this file to .env.local and fill in values.
# The app boots with just ANTHROPIC_API_KEY + the two
# NEXT_PUBLIC_SUPABASE_* vars. Everything else is optional
# and degrades gracefully (sources marked "unavailable").
# ─────────────────────────────────────────────

# Anthropic (REQUIRED) — resume parsing, matching, cover letters
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (REQUIRED) — jobs cache, sessions, saved jobs
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Vercel Blob (OPTIONAL) — resume file storage.
# If absent, parsing still works from extracted text; file just isn't persisted.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Upstash Redis (OPTIONAL) — job source caching (2h TTL).
# If absent, sources are fetched live every time (slower, still works).
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# RapidAPI / JSearch (OPTIONAL) — international + aggregated listings.
# If absent, the jsearch source is skipped.
RAPIDAPI_KEY=...

# Python Scraper Microservice (OPTIONAL) — Mustakbil + NTS/FPSC.
# If absent, those sources are skipped. Deploy scraper-service/ to Railway.
SCRAPER_SERVICE_URL=https://your-scraper.up.railway.app

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=replace_with_a_random_32_char_string
